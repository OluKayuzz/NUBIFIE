@Model.NewsDetail NUBIFIE_Web_Portal.Models.NewsDetailsViewModel

@{
    ViewData["Title"] = "News Details";
}


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>NUBIFIE - News Details</title>
    <meta content="" name="description">
    <meta content="" name="keywords">

    <!-- =======================================================
    * Template Name: ZenBlog
    * Template URL: https://bootstrapmade.com/zenblog-bootstrap-blog-template/
    * Updated: Mar 17 2024 with Bootstrap v5.3.3
    * Author: BootstrapMade.com
    * License: https:///bootstrapmade.com/license/
    ======================================================== -->
</head>

    <body>

        <main id="main">

            <section class="single-post-content">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-12 text-center mb-5">
                            <h1 class="page-title">News</h1>
                        </div>
                        <div class="col-md-9 post-content" data-aos="fade-up">
                            <div class="row">
                                <!-- ======= Single Post Content ======= -->
                                    <div class="single-post">
                                        <div class="post-meta">
                                            <span class="date">
                                                @Model.NewsDetail.Category
                                            </span> 
                                            <span class="mx-1">&bullet;</span> 
                                            <span>
                                                @Model.NewsDetail.NewsDate.ToString("dd MMMM yyyy")
                                            </span>
                                        </div>
                                        <h1 class="mb-5">@Model.NewsDetail.NewsTitle</h1>

                                        <!--<figure class="my-4">-->
                                            <img src="~/news/Image/@Model.NewsDetail.NewsCoverPicAddress" alt="" class="img-fluid">
                                        <figcaption>@(string.IsNullOrEmpty(Model.NewsDetail.NewsCoverPicCaption) ? "" : Model.NewsDetail.NewsCoverPicCaption)</figcaption>
                                        <!--</figure>-->
                                        <br />
                                        @{
                                            // Extract the rest of the content excluding the first character
                                            var restOfContent = (string.IsNullOrEmpty(Model.NewsDetail.NewsContent) || Model.NewsDetail.NewsContent.Length <= 1 ? "" : Model.NewsDetail.NewsContent.Substring(1));

                                            // Replace new lines with <br /> tags
                                            var formattedContent = restOfContent.Replace("\r\n", "<br />").Replace("\n", "<br />");
                                        }

                                        <p>
                                            <span class="firstcharacter">
                                            @(string.IsNullOrEmpty(Model.NewsDetail.NewsContent) ? "" : Model.NewsDetail.NewsContent.Substring(0, 1))
                                            </span>
                                            @Html.Raw(formattedContent)
                                        </p>
                                        <p></p>

                                        @if (@Model.NewsDetail.NewsUrl != null || @Model.NewsDetail.NewsUrl != String.Empty)
                                        {
                                            <p><a href="@Model.NewsDetail.NewsUrl" target="_blank">Click here for further details.</a></p>
                                        }
                                    </div><!-- End Single Post Content -->
                                </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row">
                                        <!-- ======= Video ======= -->
                                    @if ((Model.NewsDetail.NewsHasVideo) && (!string.IsNullOrEmpty(Model.NewsDetail.NewsVideoAddress)))
                                        {
                                            <h3 class="aside-title">Video</h3>
                                            <div class="aside-block">
                                                <div class="video-post">
                                                    <a href="~/news/Video/@Model.NewsDetail.NewsVideoAddress" class="glightbox link-video" data-type="video">
                                                        <span class="bi-play-fill"></span>
                                                        <img src="~/news/Video/video-file_color.png" alt="" class="img-fluid">
                                                    </a>
                                                </div>
                                            </div>
                                            <!-- End Video -->
                                        }
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row">
                                        <!-- ======= Audio ======= -->
                                    @if ((Model.NewsDetail.NewsHasAudio) && (!string.IsNullOrEmpty(Model.NewsDetail.NewsAudioAddress)))
                                        {
                                            <h3 class="aside-title">Audio</h3>
                                            <div class="aside-block">
                                                <div class="audio-post">
                                                    <audio controls>
                                                        <source src="~/news/Audio/@Model.NewsDetail.NewsAudioAddress" type="audio/mpeg">
                                                        <img src="~/news/Audio/music.png" alt="" class="img-fluid">
                                                        Your browser does not support the audio element.
                                                    </audio>
                                                </div>
                                            </div>
                                            <!-- End Audio -->
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="row">
                                <!-- ======= Sidebar ======= -->
                                <div class="aside-block">

                                    <ul class="nav nav-pills custom-tab-nav mb-4" id="pills-tab" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active" id="pills-popular-tab" data-bs-toggle="pill" data-bs-target="#pills-popular" type="button" role="tab" aria-controls="pills-popular" aria-selected="true">Popular</button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link" id="pills-latest-tab" data-bs-toggle="pill" data-bs-target="#pills-latest" type="button" role="tab" aria-controls="pills-latest" aria-selected="false">Latest</button>
                                        </li>
                                    </ul>

                                    <div class="tab-content" id="pills-tabContent">

                                        <!-- Popular -->
                                        <div class="tab-pane fade show active" id="pills-popular" role="tabpanel" aria-labelledby="pills-popular-tab">
                                            @foreach (var obj in Model.OrderedByViewFrequency)
                                            {
                                                <div class="post-entry-1 border-bottom">
                                                    <div class="post-meta"><span class="date">@obj.Category</span> <span class="mx-1">&bullet;</span> <span>@obj.NewsDate.ToString("dd MMMM yyyy")</span></div>
                                                    <h2 class="mb-2"><a asp-controller="News" asp-action="Details" asp-route-id="@obj.Id">@obj.NewsTitle</a></h2>
                                                    <span class="author mb-3 d-block">@obj.NewsSource</span>
                                                </div>
                                            }
                                        </div> <!-- End Popular -->
                                        <!-- Latest -->
                                        <div class="tab-pane fade" id="pills-latest" role="tabpanel" aria-labelledby="pills-latest-tab">
                                            @foreach (var obj in Model.OrderedByDate)
                                            {
                                                <div class="post-entry-1 border-bottom">
                                                    <div class="post-meta"><span class="date">@obj.Category</span> <span class="mx-1">&bullet;</span> <span>@obj.NewsDate.ToString("dd MMMM yyyy")</span></div>
                                                    <h2 class="mb-2"><a asp-controller="News" asp-action="Details" asp-route-id="@obj.Id">@obj.NewsTitle</a></h2>
                                                    <span class="author mb-3 d-block">NewsSource</span>
                                                </div>
                                            }
                                        </div> <!-- End Latest -->

                                    </div>
                                </div>
                                <div class="row">
                                    <div><a asp-controller="News" asp-action="Index" class="more">See All News</a></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    <!-- End #main -->
        <!-- ======= Footer ======= -->
        <footer id="footer" class="footer">

            <div class="footer-legal">
                <div class="container">

                    <div class="row justify-content-between">
                        <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                            <div class="copyright">
                                © Copyright <strong><span>NUBIFIE</span></strong>. All Rights Reserved
                            </div>

                            <div class="credits">
                                <!-- All the links in the footer should remain intact. -->
                                <!-- You can delete the links only if you purchased the pro version. -->
                                <!-- Licensing information: https://bootstrapmade.com/license/ -->
                                <!-- Purchase the pro version with working PHP/AJAX contact form: https://bootstrapmade.com/herobiz-bootstrap-business-template/ -->
                                Designed by <a href="https://flintvision.com/">FlintVision Technology</a>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="social-links mb-3 mb-lg-0 text-center text-md-end">
                                <a href="#" title="X (Twitter)" class="twitter"><i class="bi bi-twitter"></i></a>
                                <a href="#" title="Facebook" class="facebook"><i class="bi bi-facebook"></i></a>
                                <a href="#" title="Instagram" class="instagram"><i class="bi bi-instagram"></i></a>
                                <a href="#" title="Skype" class="google-plus"><i class="bi bi-skype"></i></a>
                                <!-- <a href="#" class="linkedin"><i class="bi bi-linkedin"></i></a> -->
                            </div>

                        </div>

                    </div>

                </div>
            </div>

        </footer>

        <a href="#" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

        <!-- Vendor JS Files -->
        <script src="~/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="~/assets/vendor/swiper/swiper-bundle.min.js"></script>
        <script src="~/assets/vendor/glightbox/js/glightbox.min.js"></script>
        <script src="~/assets/vendor/aos/aos.js"></script>
        <script src="~/assets/vendor/php-email-form/validate.js"></script>

        <!-- Template Main JS File -->
        <script src="~/assets/js/main.js"></script>

    </body>

</html>
